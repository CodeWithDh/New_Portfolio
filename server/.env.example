# ─────────────────────────────────────────────────────────────────
# Portfolio Server – Runtime Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to server/.env and fill in your values.
# NEVER commit server/.env to git – it contains secrets.
# ─────────────────────────────────────────────────────────────────

# Server port (default: 5001)
PORT=5001

# Gmail credentials for the contact-form email (POST /api/contact)
# Use a Gmail App Password – NOT your main account password.
# How to create one: https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
